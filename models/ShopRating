const mongoose = require("mongoose");

const shopRatingSchema = new mongoose.Schema({
    shopId: {
        type: mongoose.Schema.Types.ObjectId,
        ref: "Shop",
        required: true
    },
    userId: {
        type: mongoose.Schema.Types.ObjectId,
        ref: "Customer",
        required: true
    },
    rating: {
        type: Number,
        required: true,
        min: 0,
        max: 5
    }
}, { timestamps: true });

shopRatingSchema.index({ shopId: 1, userId: 1 }, { unique: true });

module.exports = mongoose.model("ShopRating", shopRatingSchema);